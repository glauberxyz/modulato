{
  "name": "modulato",
  "version": "0.1.3",
  "description": "Animation-first React framework for marketing sites, landing pages and portfolios.",
  "license": "MIT",
  "homepage": "https://github.com/glauberxyz/modulato#readme",
  "type": "module",
  "bin": {
    "modulato": "bin/modulato.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.tsx",
    "./cli": "./bin/lib/index.mjs",
    "./config": {
      "types": "./src/config.ts",
      "default": "./config.mjs"
    }
  },
  "files": [
    "src",
    "bin",
    "config.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "lenis": "^1.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "keywords": [
    "react",
    "animation",
    "framework",
    "transitions",
    "gsap",
    "lenis",
    "marketing-site"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glauberxyz/modulato.git",
    "directory": "framework/core"
  },
  "bugs": "https://github.com/glauberxyz/modulato/issues"
}
